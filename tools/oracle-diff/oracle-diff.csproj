<Project Sdk="Microsoft.NET.Sdk">

  <!--
    差分オラクル用 C# コンソール。原典 SRCCore の Expression エンジンを standalone で
    駆動し、標準入力の式 (1 行 1 式) を評価して結果を標準出力に返す。
    Rust 評価器の出力と突き合わせることで、式層の挙動を自動検証する。
    詳細な使い方は同ディレクトリの README.md を参照。
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>oracle-diff</AssemblyName>
    <RootNamespace>OracleDiff</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../../SRC.Sharp/SRC.Sharp/SRCCore/SRCCore.csproj" />
  </ItemGroup>

</Project>
